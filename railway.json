{
  "$schema": "https://railway.app/railway.schema.json",
  "env": {
    "OPENROUTER_API_KEY": {
      "description": "Your OpenRouter API key (from openrouter.ai/keys)",
      "required": true
    },
    "TELEGRAM_BOT_TOKEN": {
      "description": "Telegram bot token from @BotFather",
      "required": true
    },
    "OPENCLAW_AGENT_NAME": {
      "description": "Your agent's display name",
      "required": true
    },
    "OPENCLAW_GATEWAY_TOKEN": {
      "description": "Auto-generated token for gateway authentication",
      "default": "${{secret(64)}}"
    },
    "OPENCLAW_GATEWAY_PASSWORD": {
      "description": "Auto-generated password for gateway authentication",
      "default": "${{secret(32)}}"
    }
  },
  "volumes": {
    "/data": {}
  },
  "deploy": {
    "startCommand": "docker-entrypoint.sh openclaw gateway --allow-unconfigured --bind lan",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300
  }
}
